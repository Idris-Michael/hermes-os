# ─── hermes-hub environment ───────────────────────────────
# Copy to .env.local and fill in the keys you have.

# Anthropic — reasoning + chat orchestrator
ANTHROPIC_API_KEY=

# Google — Gemini + GA4
GEMINI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# HuggingFace — Qwen / DeepSeek inference
HF_API_TOKEN=

# Telegram — notifications and approval routing
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CREATIVE_CHAT_ID=

# Meta — Instagram publishing
META_IG_TOKEN=
IG_BUSINESS_ID_SEVERUS=
IG_BUSINESS_ID_MIKEB=

# Obsidian Local REST API
OBSIDIAN_API_KEY=
OBSIDIAN_API_URL=http://localhost:27123

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# Hub
HUB_PORT=3000
APPROVAL_HMAC_SECRET=
HUB_BASE_URL=http://localhost:3000
